#!/bin/sh
# Enforce Conventional Commits on the subject line.
# Tracked hook; activated per-clone via:  git config core.hooksPath .githooks
subject=$(head -n1 "$1")

# Let git-generated / housekeeping messages through.
case "$subject" in
  "Merge "*|"Revert "*|"fixup!"*|"squash!"*|"amend!"*) exit 0 ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._-]+\))?!?: .+'
if ! printf '%s' "$subject" | grep -Eq "$pattern"; then
  echo "✗ Commit message must follow Conventional Commits:" >&2
  echo "    type(scope): description     e.g.  feat(concat): add glueD'_spec" >&2
  echo "  allowed types: feat fix docs style refactor perf test build ci chore revert" >&2
  echo "  got: $subject" >&2
  exit 1
fi
